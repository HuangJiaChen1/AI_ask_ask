graph TD
    %% ====================================================================
    %% PAIXUEJI ACTION FLOW GRAPH - Complete System Flow
    %% Root: USER clicks "Start Conversation"
    %% Medium granularity: validation, streaming, classification
    %% Inline errors: every decision shows success + failure paths
    %% Streaming mechanics: SSE chunk-by-chunk visible
    %% ====================================================================

    ROOT[👤 USER clicks Start Conversation]

    %% ====================================================================
    %% PHASE 1: INITIALIZATION
    %% ====================================================================
    subgraph Phase1[" PHASE 1: INITIALIZATION "]
        direction TB

        A1[👤 USER_fill_form<br/>Enter age, object, categories, tone, focus]
        A2{🔍 Validate Input<br/>object_name not empty?}
        A3[👤 USER_click_classify<br/>Optional: Auto-populate categories]
        A4[🌐 API_POST_/classify<br/>Request classification]
        A5[🤖 AI_classify_object<br/>Gemini call<br/>timeout: 1s]
        A6{⏱️ Classification Success?}
        A7[💻 FE_update_dropdowns<br/>Auto-select categories]
        A8[💻 FE_show_error<br/>Timeout or error,<br/>manual selection]
        A9[👤 USER_click_start<br/>Start Learning button]
        A10{🔍 Validate Form<br/>object not empty?}
        A11[🌐 API_POST_/start<br/>POST request with all fields]
        A12{🔍 Backend Validation<br/>required fields present?}
        A13[🔴 HTTP 400<br/>Missing required fields]
        A14[💻 FE_show_error<br/>Please enter object name]

        A1 --> A2
        A2 -->|Valid| A3
        A2 -->|Invalid| A14
        A3 --> A4
        A4 --> A5
        A5 --> A6
        A6 -->|Success < 1s| A7
        A6 -->|Timeout >= 1s<br/>OR Error| A8
        A7 --> A9
        A8 --> A9
        A2 -->|Skip Classify| A9
        A9 --> A10
        A10 -->|Valid| A11
        A10 -->|Invalid| A14
        A11 --> A12
        A12 -->|Valid| B1
        A12 -->|Invalid| A13
    end

    %% ====================================================================
    %% PHASE 2: SSE SETUP
    %% ====================================================================
    subgraph Phase2[" PHASE 2: SSE SETUP "]
        direction TB

        B1[⚙️ BE_create_session<br/>Generate UUID<br/>Create PaixuejiAssistant]
        B2[⚙️ BE_prepare_system_prompts<br/>Assemble system message<br/>age + tone + category + focus]
        B3[⚙️ BE_create_event_loop<br/>asyncio.new_event_loop]
        B4[⚙️ BE_call_paixueji_stream<br/>Main orchestrator<br/>async generator]
        B5{🔍 First Interaction?<br/>correct_count==0 &&<br/>no assistant messages}

        B1 --> B2
        B2 --> B3
        B3 --> B4
        B4 --> B5
        B5 -->|Yes| C1
        B5 -->|No| D1
    end

    %% ====================================================================
    %% PHASE 3: INTRODUCTION FLOW
    %% ====================================================================
    subgraph Phase3[" PHASE 3: INTRODUCTION "]
        direction TB

        C1[⚙️ BE_route_to_introduction]
        C2[⚙️ BE_prepare_messages<br/>Shallow copy history]
        C3[⚙️ BE_convert_to_gemini<br/>OpenAI → Gemini format]
        C4[🤖 AI_stream_introduction<br/>Stream first question<br/>temp=0.3]
        C5{🔍 Gemini API Success?}
        C6["🔴 Fallback Question<br/>'Tell me about {object}!'"]
        C7[⚡ SSE Stream Loop<br/>Chunk 0, 1, 2, ...]
        C8[💻 FE_buffer_sse_data<br/>Accumulate until \n\n]
        C9[💻 FE_parse_sse_event<br/>Extract event + data]
        C10{🔍 Event Type?}
        C11[💻 FE_render_text_chunk<br/>Append to message bubble]
        C12[💻 FE_show_error<br/>Display error message]
        C13[⚙️ BE_update_conversation_history<br/>Append assistant message]
        C14[⚡ BE_emit_sse_complete<br/>event: complete]
        C15[💻 FE_enable_send_button<br/>isStreaming = false]
        C16[⏸️ WAIT for user message]

        C1 --> C2
        C2 --> C3
        C3 --> C4
        C4 --> C5
        C5 -->|Success| C7
        C5 -->|Error| C6
        C6 --> C7
        C7 --> C8
        C8 --> C9
        C9 --> C10
        C10 -->|chunk| C11
        C10 -->|error| C12
        C10 -->|complete| C15
        C11 -.->|More chunks| C7
        C7 -.->|finish=true| C13
        C13 --> C14
        C14 --> C15
        C15 --> C16
    end

    %% ====================================================================
    %% CONVERSATION LOOP ENTRY
    %% ====================================================================
    C16 --> D0

    subgraph ConversationLoop[" CONVERSATION LOOP (Infinite) "]
        direction TB

        D0[👤 USER_send_message<br/>Type answer + Enter/Send]
        D0A{🔍 Already streaming?}
        D0B[💻 FE_abort_stream<br/>AbortController.abort]

        D0 --> D0A
        D0A -->|Yes| D0B
        D0A -->|No| D1
        D0B --> D1

    %% ====================================================================
    %% PHASE 4: DUAL-PARALLEL VALIDATION & ROUTING
    %% ====================================================================

    subgraph Phase4[" PHASE 4: VALIDATION & ROUTING "]
        direction TB
        D1["🌐 API_POST_/continue<br/>POST {session_id, child_input, focus_mode}"]
        D2{🔍 Session Exists?}
        D3[🔴 HTTP 404<br/>Session not found]
        D4["⚙️ BE_lookup_session<br/>sessions[session_id]"]
        D5[⚙️ Append user message<br/>to conversation_history]
        D6[⚙️ BE_call_paixueji_stream<br/>Orchestrator]
        D7[🔶 VALIDATE_unified_ai<br/>3-part AI validation<br/>Gemini JSON mode]
        D8{🔍 Validation Success?}
        D9[🔴 Validation Error<br/>Use safe defaults:<br/>engaged=true, correct=true, CONTINUE]
        D10[🔶 Extract Validation Results<br/>is_engaged, is_factually_correct,<br/>decision SWITCH/CONTINUE, new_object]
        D11[🔶 VALIDATE_system_focus<br/>Decide next focus mode<br/>IF system_managed]
        D12[🔶 VALIDATE_route_decision<br/>Choose 1 of 5 response paths]
        D13{🔍 Routing Logic}

        D1 --> D2
        D2 -->|No| D3
        D2 -->|Yes| D4
        D4 --> D5
        D5 --> D6
        D6 --> D7
        D7 --> D8
        D8 -->|Success| D10
        D8 -->|Error| D9
        D9 --> D10
        D10 --> D11
        D11 --> D12
        D12 --> D13

        %% 5 Routing Paths
        D13 -->|decision=SWITCH<br/>AND new_object=null| E1_ExplicitSwitch
        D13 -->|is_engaged=false| E2_Explanation
        D13 -->|engaged + correct + SWITCH<br/>+ new_object| E3_TopicSwitch
        D13 -->|engaged + correct + CONTINUE| E4_Feedback
        D13 -->|engaged + wrong| E5_Correction
    end

    %% ====================================================================
    %% PHASE 5: RESPONSE STREAMING (5 Paths)
    %% ====================================================================

    subgraph Phase5[" PHASE 5: RESPONSE STREAMING "]
        direction TB

        %% PATH 1: Explicit Switch (no object named)
        E1_ExplicitSwitch[🤖 AI_generate_suggestions<br/>Get 3-4 suggested objects<br/>Gemini JSON mode]
        E1_Response[🤖 AI_stream_explicit_switch<br/>Stream response with suggestions<br/>Part 1 only - NO Part 2]
        E1_Chunks[⚡ SSE Stream Chunks<br/>suggested_objects in metadata]
        E1_Skip[⏭️ Skip Question Generation<br/>Response contains selection]

        E1_ExplicitSwitch --> E1_Response
        E1_Response --> E1_Chunks
        E1_Chunks --> E1_Skip
        E1_Skip --> F_Complete

        %% PATH 2: Explanation (not engaged / stuck)
        E2_Explanation[🤖 AI_stream_explanation<br/>Gentle help + explanation<br/>Part 1 - temp=0.3]
        E2_Chunks[⚡ SSE Stream Chunks<br/>is_engaged=false in metadata]
        E2_Append[⚙️ Append Part 1 to<br/>question_messages]

        E2_Explanation --> E2_Chunks
        E2_Chunks --> E2_Append
        E2_Append --> F_Question

        %% PATH 3: Topic Switch (correct + SWITCH + new_object)
        E3_UpdateObject[⚙️ Update assistant.object_name<br/>= new_object]
        E3_Classify[🤖 AI_classify_object<br/>Background thread<br/>timeout: 1s]
        E3_ClassifyResult{⏱️ Classify Success?}
        E3_Continue[⏭️ Continue anyway<br/>categories may be null]
        E3_UpdateCategories[⚙️ Update level1/level2 categories<br/>Update category_prompt]
        E3_ResetFocus{🔍 system_managed?}
        E3_Reset[⚙️ reset_object_state<br/>depth_count=0, width_count=0<br/>focus='depth', new target]
        E3_Response[🤖 AI_stream_topic_switch<br/>Celebrate + introduce new object<br/>Part 1]
        E3_Chunks[⚡ SSE Stream Chunks<br/>new_object_name in metadata]
        E3_Append[⚙️ Append Part 1 to<br/>question_messages]

        E3_TopicSwitch --> E3_UpdateObject
        E3_UpdateObject --> E3_Classify
        E3_Classify --> E3_ClassifyResult
        E3_ClassifyResult -->|Success < 1s| E3_UpdateCategories
        E3_ClassifyResult -->|Timeout >= 1s| E3_Continue
        E3_Continue --> E3_ResetFocus
        E3_UpdateCategories --> E3_ResetFocus
        E3_ResetFocus -->|Yes| E3_Reset
        E3_ResetFocus -->|No| E3_Response
        E3_Reset --> E3_Response
        E3_Response --> E3_Chunks
        E3_Chunks --> E3_Append
        E3_Append --> F_Question

        %% PATH 4: Feedback (correct + CONTINUE)
        E4_Feedback[🤖 AI_stream_feedback<br/>Celebrate correct answer<br/>Part 1 - temp=0.3]
        E4_Chunks[⚡ SSE Stream Chunks<br/>is_factually_correct=true]
        E4_Append[⚙️ Append Part 1 to<br/>question_messages]

        E4_Feedback --> E4_Chunks
        E4_Chunks --> E4_Append
        E4_Append --> F_Question

        %% PATH 5: Gentle Correction (wrong + engaged)
        E5_Correction[🤖 AI_stream_correction<br/>Gentle correction + accurate info<br/>Part 1 - temp=0.3]
        E5_Chunks[⚡ SSE Stream Chunks<br/>is_factually_correct=false<br/>correctness_reasoning included]
        E5_Append[⚙️ Append Part 1 to<br/>question_messages]

        E5_Correction --> E5_Chunks
        E5_Chunks --> E5_Append
        E5_Append --> F_Question
    end

    %% ====================================================================
    %% PHASE 6: QUESTION STREAMING (Part 2)
    %% ====================================================================

    subgraph Phase6[" PHASE 6: QUESTION STREAMING "]
        direction TB

        F_Question[🤖 AI_stream_followup_question<br/>Generate next question<br/>based on focus_mode<br/>Part 2 - temp=0.3]
        F_QuestionSuccess{🔍 Gemini Success?}
        F_Fallback["🔴 Fallback Question<br/>'What else can you tell me<br/>about {object}?'"]
        F_Chunks[⚡ SSE Stream Chunks<br/>response_type='followup_question']
        F_Combine[⚙️ Combine full_response<br/>= Part1 + Part2]
        F_UpdateHistory[⚙️ BE_update_conversation_history<br/>Append full_response]
        F_IncrementCheck{🔍 is_factually_correct<br/>AND finish?}
        F_Increment[⚙️ BE_increment_correct_count<br/>correct_answer_count += 1]
        F_Complete[⚡ BE_emit_sse_complete<br/>event: complete]

        F_Question --> F_QuestionSuccess
        F_QuestionSuccess -->|Success| F_Chunks
        F_QuestionSuccess -->|Error| F_Fallback
        F_Fallback --> F_Chunks
        F_Chunks --> F_Combine
        F_Combine --> F_UpdateHistory
        F_UpdateHistory --> F_IncrementCheck
        F_IncrementCheck -->|Yes| F_Increment
        F_IncrementCheck -->|No| F_Complete
        F_Increment --> F_Complete
    end

        %% Connection between phases
        F_Complete --> G1

    %% ====================================================================
    %% PHASE 7: FRONTEND RENDERING
    %% ====================================================================

    subgraph Phase7[" PHASE 7: FRONTEND RENDERING "]
        direction TB

        G1[⚡ SSE events → FE]
        G2[💻 FE_buffer_sse_data<br/>Accumulate chunks]
        G3[💻 FE_parse_sse_event<br/>Parse event type + data JSON]
        G4{🔍 Event Type?}
        G5[💻 handleStreamChunk<br/>Process StreamChunk object]
        G6{🔍 sessionId set?}
        G7[💻 Extract session_id<br/>from first chunk]
        G8{🔍 currentMessageDiv exists?}
        G9[💻 FE_create_message_bubble<br/>Create new message div]
        G10{🔍 chunk.finish?}
        G11[💻 FE_render_text_chunk<br/>Append to bubble]
        G12[💻 Finalize message<br/>Compare streamed vs final<br/>Keep longer version]
        G13{🔍 new_object_name?}
        G14[💻 FE_update_debug_panel<br/>Update currentObject]
        G15{🔍 detected_object_name?}
        G16[💻 FE_show_switch_panel<br/>Manual override UI]
        G17{🔍 suggested_objects?}
        G18[💻 FE_show_selection_panel<br/>Object choice buttons]
        G19[💻 FE_update_progress_bar<br/>correct_answer_count]
        G20[💻 FE_enable_send_button<br/>isStreaming = false]
        G21[🔴 FE_show_error<br/>Display error message]

        F_Complete --> G1
        G1 --> G2
        G2 --> G3
        G3 --> G4
        G4 -->|chunk| G5
        G4 -->|complete| G20
        G4 -->|error| G21
        G5 --> G6
        G6 -->|No| G7
        G6 -->|Yes| G8
        G7 --> G8
        G8 -->|No| G9
        G8 -->|Yes| G10
        G9 --> G10
        G10 -->|false| G11
        G10 -->|true| G12
        G11 -.->|Next chunk| G2
        G12 --> G13
        G13 -->|Yes| G14
        G13 -->|No| G15
        G14 --> G15
        G15 -->|Yes| G16
        G15 -->|No| G17
        G16 --> G17
        G17 -->|Yes| G18
        G17 -->|No| G19
        G18 --> G19
        G19 --> G20
    end

        G20 --> D0
    end

    %% ====================================================================
    %% PHASE 8: SYSTEM-MANAGED FOCUS (separate subgraph for clarity)
    %% ====================================================================
    subgraph Phase8[" PHASE 8: SYSTEM-MANAGED FOCUS TRANSITIONS "]
        direction TB

        H1[🔶 VALIDATE_system_focus<br/>Triggered before response generation<br/>IF system_managed_focus=true]
        H2{🔍 current_focus_mode?}

        %% Depth Phase
        H3_Depth[📊 DEPTH PHASE]
        H4{🔍 is_engaged?}
        H5[⚙️ depth_questions_count += 1]
        H6{🔍 depth_questions_count<br/>>= depth_target?}
        H7[⚙️ Switch to WIDTH<br/>Random: width_color/shape/category<br/>Add to width_categories_tried]
        H8[⏭️ Continue depth mode]

        %% Width Phase
        H9_Width[📊 WIDTH PHASE<br/>width_color/shape/category]
        H10{🔍 is_engaged AND<br/>is_factually_correct?}
        H11[⚙️ width_wrong_count = 0<br/>Reset on correct]
        H12[⚙️ width_wrong_count += 1<br/>Increment on wrong/stuck]
        H13{🔍 width_wrong_count >= 3?}
        H14[⏭️ Continue width mode]
        H15[🔶 VALIDATE_width_wrong<br/>Handle threshold]
        H16[⚙️ Trigger natural_topic_completion<br/>current_focus_mode = 'object_selection']

        %% Object Selection Phase
        H17_Selection[📊 OBJECT SELECTION PHASE]
        H18[🤖 AI_stream_natural_completion<br/>Congratulate + ask what next<br/>Natural language, no UI list]
        H19[⏸️ Wait for user input<br/>AI will detect SWITCH<br/>in next validation]

        H1 --> H2
        H2 -->|depth| H3_Depth
        H2 -->|width_*| H9_Width
        H2 -->|object_selection| H17_Selection

        H3_Depth --> H4
        H4 -->|Yes| H5
        H4 -->|No| H8
        H5 --> H6
        H6 -->|Yes| H7
        H6 -->|No| H8

        H9_Width --> H10
        H10 -->|Yes| H11
        H10 -->|No| H12
        H11 --> H14
        H12 --> H13
        H13 -->|Yes| H15
        H13 -->|No| H14
        H15 --> H16

        H17_Selection --> H18
        H18 --> H19
    end

    %% ====================================================================
    %% PHASE 9: ERROR HANDLING & EDGE CASES
    %% ====================================================================
    subgraph Phase9[" PHASE 9: ERROR HANDLING "]
        direction TB

        I1[🔴 Stream Abort<br/>USER_click_stop]
        I2[💻 FE_abort_stream<br/>AbortController.abort]
        I3[⚙️ BE receives GeneratorExit]
        I4[📝 Log disconnect<br/>Cleanup stream]
        I5[💻 FE re-enable send button<br/>Partial response visible]

        I6[🔴 HTTP Errors]
        I7{🔍 Status Code?}
        I8[🔴 400: Validation Error<br/>Missing fields]
        I9[🔴 404: Session Not Found<br/>Server restarted or expired]
        I10[🔴 500: Server Error<br/>Backend exception]
        I11[💻 FE_show_error<br/>Display error message]
        I12[💻 Prompt user to restart<br/>Session lost]

        I13[🔴 Validation Timeout/Error]
        I14[⚙️ Use safe defaults<br/>engaged=true, correct=true, CONTINUE]
        I15[📝 Log error<br/>Continue conversation]

        I16[🔴 Classification Timeout 1s]
        I17[⚙️ Continue with null categories<br/>No blocking on classification]

        I18[🔴 SSE Parse Error]
        I19[💻 Skip malformed event<br/>Log warning<br/>Wait for next event]

        I1 --> I2
        I2 --> I3
        I3 --> I4
        I4 --> I5

        I6 --> I7
        I7 -->|400| I8
        I7 -->|404| I9
        I7 -->|500| I10
        I8 --> I11
        I9 --> I12
        I10 --> I11

        I13 --> I14
        I14 --> I15

        I16 --> I17

        I18 --> I19
    end

    %% ====================================================================
    %% MANUAL OVERRIDE (User Action)
    %% ====================================================================
    subgraph ManualActions[" MANUAL OVERRIDE "]
        direction TB

        J1[👤 USER_force_switch<br/>Click 'Switch to X' button<br/>detected_object panel]
        J2["🌐 API_POST_/force-switch<br/>POST {session_id, new_object}"]
        J3[⚙️ Update assistant.object_name<br/>Classify new object 1s timeout]
        J4[💻 FE_dismiss_switch_panel<br/>FE_add_system_message<br/>FE_update_debug_panel]

        J1 --> J2
        J2 --> J3
        J3 --> J4
    end

    %% NOTE: Object selection uses natural language instead of UI buttons
    %% When AI generates suggested_objects in explicit_switch response,
    %% user types their choice as next message instead of clicking buttons

    %% ====================================================================
    %% ROOT CONNECTION
    %% ====================================================================
    ROOT --> Phase1

    %% ====================================================================
    %% COLOR CLASSES
    %% ====================================================================
    classDef user fill:#e3f2fd,stroke:#2196f3,stroke-width:2px,color:#000
    classDef frontend fill:#f3e5f5,stroke:#9c27b0,stroke-width:2px,color:#000
    classDef backend fill:#fff9c4,stroke:#fbc02d,stroke-width:2px,color:#000
    classDef ai fill:#e8f5e9,stroke:#4caf50,stroke-width:2px,color:#000
    classDef error fill:#ffebee,stroke:#f44336,stroke-width:2px,color:#000
    classDef validate fill:#fff3e0,stroke:#ff9800,stroke-width:2px,color:#000
    classDef decision fill:#fce4ec,stroke:#e91e63,stroke-width:2px,color:#000
    classDef sse fill:#e0f2f1,stroke:#009688,stroke-width:2px,color:#000

    class ROOT user
    class A1,A3,A9,D0,J1,J5 user
    class A2,A10,B5,C5,C10,D0A,D2,D8,D13,E3_ClassifyResult,E3_ResetFocus,F_QuestionSuccess,F_IncrementCheck,G4,G6,G8,G10,G13,G15,G17,H2,H4,H6,H10,H13,I7 decision
    class A7,A8,A14,C8,C9,C11,C12,C15,D0B,G2,G3,G5,G7,G9,G11,G12,G14,G16,G18,G19,G20,I2,I5,I11,I12,I19,J4,J8 frontend
    class B1,B2,B3,B4,C1,C2,C3,C13,D4,D5,D6,E3_UpdateObject,E3_Continue,E3_UpdateCategories,E3_Reset,E2_Append,E3_Append,E4_Append,E5_Append,F_Combine,F_UpdateHistory,F_Increment,I3,I4,I14,I15,I17,J3,J7 backend
    class A4,A11,D1,J2,J6 backend
    class A5,C4,E1_ExplicitSwitch,E2_Explanation,E3_Classify,E3_Response,E4_Feedback,E5_Correction,F_Question,H18 ai
    class C6,C12,A13,D3,I1,I6,I8,I9,I10,I13,I16,I18,F_Fallback error
    class D7,D10,D11,D12,H1,H15 validate
    class C7,C14,E1_Chunks,E2_Chunks,E3_Chunks,E4_Chunks,E5_Chunks,F_Chunks,F_Complete,G1 sse
    class H3_Depth,H5,H7,H8,H9_Width,H11,H12,H14,H16,H17_Selection,H19 validate

    class A6 decision
    class A12 decision
    class C21,G21,I21 error
