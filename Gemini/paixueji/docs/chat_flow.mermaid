%%{init: {'theme': 'base', 'themeVariables': { 'fontSize': '12px'}}}%%
flowchart TD
    %% ==================== 第一层：开始 ====================
    START([开始对话]) --> SELECT_OBJ[选择物体<br/>如: 苹果]
    SELECT_OBJ --> INTRO_Q[AI提出第一个问题<br/>例: 苹果是什么颜色?]
    INTRO_Q --> CHILD_REPLY[孩子回复]

    %% ==================== 第二层：统一验证 ====================
    CHILD_REPLY --> VALIDATE[/"统一AI验证<br/>decide_topic_switch_with_validation()"/]

    VALIDATE --> VALIDATE_OUT[/"输出:<br/>• is_engaged 是否参与<br/>• is_factually_correct 是否正确<br/>• decision: SWITCH/CONTINUE<br/>• new_object: 新话题名"/]

    %% ==================== 第三层：路由决策树 ====================
    VALIDATE_OUT --> ROUTE_1{"① decision<br/>== SWITCH?"}

    ROUTE_1 -->|YES| ROUTE_1A{"有指定<br/>new_object?"}
    ROUTE_1A -->|NO<br/>如:换个东西聊| PATH_EXPLICIT[路径A1: 显式切换请求]
    ROUTE_1A -->|YES<br/>如:我想聊汽车| PATH_SWITCH[路径A2: 话题切换]

    ROUTE_1 -->|NO| ROUTE_2{"② is_engaged?"}
    ROUTE_2 -->|NO<br/>如:不知道/idk| PATH_EXPLAIN[路径B: 不参与/卡住]

    ROUTE_2 -->|YES| ROUTE_3{"③ is_factually<br/>_correct?"}
    ROUTE_3 -->|YES| PATH_CORRECT[路径C: 答对了]
    ROUTE_3 -->|NO| PATH_WRONG[路径D: 答错了]

    %% ==================== 第四层：生成回复 ====================
    PATH_EXPLICIT --> GEN_EXPLICIT["生成回复:<br/>询问想聊什么 + 提供选项<br/><br/>例: 好呀! 你想聊<br/>香蕉、汽车还是小狗?"]

    PATH_SWITCH --> GEN_SWITCH["生成回复:<br/>切换庆祝 + 新话题第一问<br/><br/>例: 好呀! 汽车很有趣!<br/>你知道汽车有几个轮子吗?"]

    PATH_EXPLAIN --> GEN_EXPLAIN["生成回复:<br/>解释答案 + 下一个问题<br/><br/>例: 没关系! 苹果是红色的哦~<br/>那你知道苹果吃起来什么味道吗?"]

    PATH_CORRECT --> GEN_CORRECT["生成回复:<br/>表扬 + 下一个问题<br/>correct_count++<br/><br/>例: 太棒了! 确实是红色!<br/>那苹果吃起来什么味道呢?"]

    PATH_WRONG --> GEN_WRONG["生成回复:<br/>温和纠正 + 下一个问题<br/><br/>例: 你想得很认真! 不过苹果<br/>其实是红色的哦~ 那你知道<br/>苹果可以用来做什么吗?"]

    %% ==================== 第五层：回到循环 ====================
    GEN_EXPLICIT --> WAIT_SELECT[等待孩子选择话题]
    WAIT_SELECT --> CHILD_REPLY

    GEN_SWITCH --> CHILD_REPLY
    GEN_EXPLAIN --> CHILD_REPLY
    GEN_CORRECT --> CHILD_REPLY
    GEN_WRONG --> CHILD_REPLY

    %% ==================== 样式定义 ====================
    style START fill:#4CAF50,color:#fff
    style VALIDATE fill:#FF9800,color:#fff
    style VALIDATE_OUT fill:#FFE0B2
    style ROUTE_1 fill:#E91E63,color:#fff
    style ROUTE_1A fill:#E91E63,color:#fff
    style ROUTE_2 fill:#E91E63,color:#fff
    style ROUTE_3 fill:#E91E63,color:#fff
    style PATH_EXPLICIT fill:#9C27B0,color:#fff
    style PATH_SWITCH fill:#9C27B0,color:#fff
    style PATH_EXPLAIN fill:#2196F3,color:#fff
    style PATH_CORRECT fill:#4CAF50,color:#fff
    style PATH_WRONG fill:#FF5722,color:#fff
    style GEN_EXPLICIT fill:#E1BEE7
    style GEN_SWITCH fill:#E1BEE7
    style GEN_EXPLAIN fill:#BBDEFB
    style GEN_CORRECT fill:#C8E6C9
    style GEN_WRONG fill:#FFCCBC
