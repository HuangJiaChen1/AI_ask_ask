%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#dbeafe', 'primaryTextColor': '#1e3a5f', 'primaryBorderColor': '#3b82f6', 'lineColor': '#6b7280', 'secondaryColor': '#f0fdf4', 'tertiaryColor': '#fef9c3'}}}%%
flowchart TD
    START([START])
    FINISH([END])

    START --> rfs

    %% --- ROUTERS / GATES --------------------------------------------------
    rfs{"route_from_start"}
    intent_router{"route_from_analyze_input"}
    idk_gate{"idk_gate"}
    correct_gate{"correct_threshold_gate"}
    guide_route{"route_after_navigator"}

    %% --- ENTRY LANE -------------------------------------------------------
    subgraph INTRO ["Entry"]
        gi["generate_intro"]
    end

    %% --- CHAT LANE --------------------------------------------------------
    subgraph CHAT ["Chat"]
        ai["analyze_input"]
        ai --> intent_router
    end

    %% --- INTENT HANDLERS LANE --------------------------------------------
    subgraph INTENTS ["Intent Handlers"]
        curiosity["curiosity"]
        idk["clarifying_idk"]
        give_answer["give_answer_idk"]
        wrong["clarifying_wrong"]
        constraint["clarifying_constraint"]
        correct["correct_answer"]
        informative["informative"]
        play["play"]
        emotional["emotional"]
        avoidance["avoidance"]
        boundary["boundary"]
        action["action"]
        social["social"]
        social_ack["social_acknowledgment"]
    end

    %% --- GUIDE LANE -------------------------------------------------------
    subgraph GUIDE ["Guide Mode"]
        classify["classify_theme"]
        sg["start_guide"]
        gn["guide_navigator"]
        gd["guide_driver"]
        gh["guide_hint"]
        gs["guide_success"]
        ge["guide_exit"]
        classify --> sg
        gn --> guide_route
    end

    fin["finalize"]

    %% --- ENTRY ROUTING ----------------------------------------------------
    rfs -->|"first turn"| gff
    rfs -->|"guide_phase in {active, hint}"| gn
    rfs -->|"otherwise"| ai

    %% --- INTRO FLOW -------------------------------------------------------
    gi --> fin

    %% --- INTENT ROUTING ---------------------------------------------------
    intent_router -->|"intent=clarifying_idk or clarifying_wrong"| struggle_gate
    struggle_gate -->|"consecutive_struggle_count < 2 (1st struggle)"| idk
    struggle_gate -->|"consecutive_struggle_count >= 2 (2nd+ struggle)"| give_answer

    intent_router -->|intent=correct_answer| correct_gate
    correct_gate -->|"correct_answer_count + 1 >= GUIDE_MODE_THRESHOLD"| classify
    correct_gate -->|otherwise| correct

    intent_router -->|intent=curiosity| curiosity
    intent_router -->|intent=clarifying_wrong| wrong
    intent_router -->|intent=clarifying_constraint| constraint
    intent_router -->|intent=informative| informative
    intent_router -->|intent=play| play
    intent_router -->|intent=emotional| emotional
    intent_router -->|intent=avoidance| avoidance
    intent_router -->|intent=boundary| boundary
    intent_router -->|intent=action| action
    intent_router -->|intent=social| social
    intent_router -->|intent=social_acknowledgment| social_ack
    %% --- GUIDE ENTRY ------------------------------------------------------
    sg --> fin

    %% --- GUIDE ROUTING ----------------------------------------------------
    guide_route -->|"guide_strategy=COMPLETE OR guide_status=COMPLETED"| gs
    guide_route -->|"guide_turn_count >= guide_max_turns AND hint_given=false"| gh
    guide_route -->|"(consecutive_stuck_count >= 2 AND scaffold_level >= 4) OR (guide_turn_count >= guide_max_turns AND hint_given=true)"| ge
    guide_route -->|otherwise| gd

    %% --- HANDLERS -> FINALIZE ---------------------------------------------
    idk -->|"response=clarifying_idk; (struggle_count tracked upstream)"| fin
    give_answer -->|"response=give_answer_idk; consecutive_struggle_count = 0 (cycle reset)"| fin
    curiosity & wrong & constraint & correct & informative & play & emotional & avoidance & boundary & action & social & social_ack --> fin

    %% --- GUIDE OUTCOMES -> FINALIZE ---------------------------------------
    gs & gh & ge & gd --> fin

    fin --> FINISH
